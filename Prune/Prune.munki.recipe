<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Description</key>
	<string>Imports Prune into Munki.</string>

	<key>Identifier</key>
	<string>com.github.tonypaco.munki.Prune</string>

	<key>Input</key>
	<dict>
		<key>NAME</key>
		<string>Prune</string>

		<key>MUNKI_REPO_SUBDIR</key>
		<string>apps/%NAME%</string>

		<key>pkginfo</key>
		<dict>
			<key>catalogs</key>
			<array>
				<string>testing</string>
			</array>

			<key>category</key>
			<string>Admin Tools</string>

			<key>developer</key>
			<string>BIG-RAT</string>

			<key>display_name</key>
			<string>%NAME%</string>

			<key>name</key>
			<string>%NAME%</string>

			<key>installs</key>
			<array>
				<dict>
					<key>path</key>
					<string>/Applications/Prune.app</string>
					<key>type</key>
					<string>application</string>
				</dict>
			</array>

			<key>uninstall_method</key>
			<string>remove_app</string>
		</dict>
	</dict>

	<key>ParentRecipe</key>
	<string>com.github.ahousseini-recipes.pkg.Prune</string>

	<key>Process</key>
	<array>
		<dict>
			<key>Processor</key>
			<string>MunkiImporter</string>
		</dict>
	</array>
</dict>
</plist>
