<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Comment</key>
	<string>Created with Recipe Robot v2.5.0 (https://github.com/homebysix/recipe-robot)</string>
	<key>Description</key>
	<string>Downloads the latest version of Avogadro2.

Set PRERELEASE to a non-empty string to download prereleases, either
via Input in an override or via the -k option,
i.e.: `-k PRERELEASE=yes`

Set DOWNLOAD_ARCHITECTURE "" to download the Intel or "-arm64" for Apple Silicon. [Default: Intel]
Set MUNKI_ARCHITECTURE "x86_64" for Intel or "arm64" for Apple Silicon. [Default: Intel]</string>
	<key>Identifier</key>
	<string>com.github.tonypaco.download.Avogadro2</string>
	<key>Input</key>
	<dict>
		<key>NAME</key>
		<string>Avogadro2</string>
		<key>PRERELEASE</key>
		<string></string>
        <key>DOWNLOAD_ARCHITECTURE</key>
        <string></string>
        <key>MUNKI_ARCHITECTURE</key>
        <string>x86_64</string>
	</dict>
	<key>MinimumVersion</key>
	<string>2.3</string>
	<key>Process</key>
	<array>
		<dict>
			<key>Processor</key>
			<string>GitHubReleasesInfoProvider</string>
			<key>Arguments</key>
			<dict>
				<key>github_repo</key>
				<string>OpenChemistry/avogadroapp</string>
                <key>include_prereleases</key>
                <string>%PRERELEASE%</string>
                <key>asset_regex</key>
                <string>Avogadro2-([0-9]+(\.[0-9]+)+)-Darwin%DOWNLOAD_ARCHITECTURE%.dmg$</string>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>URLDownloader</string>
			<key>Arguments</key>
			<dict>
				<key>filename</key>
				<string>%NAME%%DOWNLOAD_ARCHITECTURE%-%version%.dmg</string>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>EndOfCheckPhase</string>
		</dict>
		<dict>
			<key>Arguments</key>
			<dict>
				<key>input_path</key>
				<string>%pathname%/Avogadro2.app</string>
				<key>requirement</key>
				<string>identifier "cc.avogadro" and anchor apple generic and certificate 1[field.1.2.840.113635.100.6.2.6] /* exists */ and certificate leaf[field.1.2.840.113635.100.6.1.13] /* exists */ and certificate leaf[subject.OU] = GEMXS2T26P</string>
			</dict>
			<key>Processor</key>
			<string>CodeSignatureVerifier</string>
		</dict>
		<dict>
			<key>Arguments</key>
			<dict>
				<key>input_plist_path</key>
				<string>%pathname%/Avogadro2.app/Contents/Info.plist</string>
				<key>plist_version_key</key>
				<string>CFBundleShortVersionString</string>
			</dict>
			<key>Processor</key>
			<string>Versioner</string>
		</dict>
	</array>
</dict>
</plist>
